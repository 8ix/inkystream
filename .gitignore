# State files (used for image rotation and device queues)
.current-state.json
.device-recent-state.json
.device-shuffle-state.json

# =============================================================================
# IMAGE STORAGE
# =============================================================================
# 
# Processed images are stored in /images/ and served via /api/img/.
# Images are runtime data - populated via Docker volume mount or local upload.
# Only the placeholder file is tracked to preserve the directory in git.
#
/images/**
!/images/.gitkeep
