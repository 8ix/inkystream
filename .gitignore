# =============================================================================
# IMAGE STORAGE
# =============================================================================
# 
# Processed images are stored in /images/ (private, not in public/).
# They are served through the authenticated /api/img/ endpoint.
#
# Track processed images - they need to be deployed to Vercel
!/images/
# Track the gitkeep but also ensure structure
!/images/.gitkeep

# Legacy public images folder (kept for backwards compatibility reference)
!/public/images/
!/public/images/.gitkeep
